{
    "version": 2,
    "framework": null,
    "buildCommand": "",
    "outputDirectory": ".",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.2"
        }
    },
    "routes": [
        {
            "src": "/assets/(.*)",
            "dest": "/public/assets/$1"
        },
        {
            "src": "/vendor/(.*)",
            "dest": "/public/vendor/$1"
        },
        {
            "src": "/favicon.ico",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "/robots.txt",
            "dest": "/public/robots.txt"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_NAME": "SRFV Games",
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_KEY": "base64:pV1BwAiQl+WQ6SXIAUNV5x+9XDuNMpl7dcCeiHbkMJg=",
        "APP_URL": "https://srfv-redux.vercel.app",
        "APP_CONFIG_CACHE": "/tmp/config.php",
        "APP_EVENTS_CACHE": "/tmp/events.php",
        "APP_PACKAGES_CACHE": "/tmp/packages.php",
        "APP_ROUTES_CACHE": "/tmp/routes.php",
        "APP_SERVICES_CACHE": "/tmp/services.php",
        "LOG_CHANNEL": "stderr",
        "DB_CONNECTION": "pgsql",
        "DATABASE_URL": "postgresql://postgres.cegiaxwwaiwtomjqsdmq:REDACTED_DB_PASS@aws-1-us-east-2.pooler.supabase.com:5432/postgres?sslmode=require",
        "DB_HOST": "aws-1-us-east-2.pooler.supabase.com",
        "DB_PORT": "5432",
        "DB_DATABASE": "postgres",
        "DB_USERNAME": "postgres.cegiaxwwaiwtomjqsdmq",
        "DB_PASSWORD": "REDACTED_DB_PASS",
        "DB_SSLMODE": "require",
        "CACHE_DRIVER": "array",
        "SESSION_DRIVER": "cookie",
        "SESSION_LIFETIME": "120",
        "SESSION_SECURE_COOKIE": "true",
        "QUEUE_CONNECTION": "sync",
        "VIEW_COMPILED_PATH": "/tmp/views"
    }
}
